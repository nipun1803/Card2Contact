PORT=4000

# Postgres connection (multi-user persistence)
DATABASE_URL=postgres://c2c:c2c@localhost:5432/card2contact

# Signs the session cookie. Must be at least 32 chars — the backend refuses to
# start otherwise.  openssl rand -hex 32
SESSION_SECRET=

# Encrypts OAuth tokens at rest (AES-256-GCM). REQUIRED — the backend exits at
# boot without it. 32 bytes as 64 hex chars or base64.  openssl rand -hex 32
# See docs/ARCHITECTURE.md → Rollback & recovery for what a lost or wrong key
# looks like.
TOKEN_ENCRYPTION_KEY=

# M2 — Text Recognition
MISTRAL_API_KEY=

# M5 — Google Sheets Integration (Google OAuth login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

FRONTEND_URL=http://localhost:5173

# NOTE: GOOGLE_SHEETS_SPREADSHEET_ID is no longer used — each user's sheet is
# auto-created on first login and stored per user in Postgres.
# NOTE: the OAuth client needs the spreadsheets AND drive.file scopes —
# drive.file is what detects a spreadsheet moved to Trash.

# Sentry error tracking (optional). Leave unset to disable, e.g. local dev/test.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

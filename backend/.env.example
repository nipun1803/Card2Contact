PORT=4000

# Postgres connection (multi-user persistence)
DATABASE_URL=postgres://c2c:c2c@localhost:5432/card2contact

# Secret used to sign the session cookie. Use a long random string.
SESSION_SECRET=

# M2 — Text Recognition
MISTRAL_API_KEY=

# M5 — Google Sheets Integration (Google OAuth login)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

FRONTEND_URL=http://localhost:5173

# NOTE: GOOGLE_SHEETS_SPREADSHEET_ID is no longer used — each user's sheet is
# auto-created on first login and stored per user in Postgres.
# NOTE: Token encryption is postponed; when enabling AesGcmTokenCodec, add
# TOKEN_ENCRYPTION_KEY (32-byte key as 64 hex chars or base64).

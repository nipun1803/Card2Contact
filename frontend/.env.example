# Standalone dev only (no nginx). Point Vite's dev proxy at the backend so
# relative /api/* calls resolve. In Docker, nginx owns /api — leave this unset.
VITE_DEV_API_TARGET=http://localhost:4000

# Feature flags (optional). Any of these set to "false" disables the feature.
# Defaults are all "true" — see src/shared/lib/featureFlags.ts.
# VITE_FLAG_CAMERA=true
# VITE_FLAG_UPLOAD=true
# VITE_FLAG_GOOGLE_OAUTH=true
# VITE_FLAG_DARK_MODE=true
# VITE_FLAG_ANIMATIONS=true
# VITE_FLAG_RECENT_SCANS=true

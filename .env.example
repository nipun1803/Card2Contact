# Copy to .env and fill in before running `docker compose up`.

# Host ports. All three services are reachable directly (useful for
# debugging) as well as through nginx's reverse proxy.
NGINX_PORT=8080
BACKEND_PORT=4000
FRONTEND_PORT=5173

# Postgres (multi-user persistence). Host maps to the compose `postgres` service.
POSTGRES_USER=c2c
POSTGRES_PASSWORD=c2c
POSTGRES_DB=card2contact
DATABASE_URL=postgres://c2c:c2c@postgres:5432/card2contact

# Signs the session cookie — the only thing between a user and a forged session
# id, so the backend refuses to start on anything shorter than 32 chars.
#   openssl rand -hex 32
SESSION_SECRET=

# Encrypts OAuth tokens at rest (AES-256-GCM). REQUIRED — the backend exits at
# boot without it, deliberately: a loud crash beats a server that fails on every
# token read. Must decode to exactly 32 bytes (64 hex chars, or base64).
#   openssl rand -hex 32
#
# Store it wherever you keep SESSION_SECRET. If it is lost, stored tokens become
# undecryptable and every user must reconnect Google once (no contact data is
# lost — that lives in Google Sheets). If it is WRONG but well-formed the
# backend still boots, and every user sees "Reconnect Google" until the correct
# key is restored. See docs/ARCHITECTURE.md → Rollback & recovery.
TOKEN_ENCRYPTION_KEY=

# M2 — Text Recognition
MISTRAL_API_KEY=

# M5 — Google Sheets Integration (Google OAuth login — see docs/modules/M5-Google-Sheets-Integration.md)
# From Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Must exactly match a redirect URI registered on that OAuth client.
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# Where the backend redirects the browser after a successful Google login.
FRONTEND_URL=http://localhost:5173

# Admin Authentication (Phase 0.1) — see docs/modules/admin/Admin-Authentication.md
#
# OPTIONAL, and strictly BOTH OR NEITHER:
#   - Leave both blank  -> the admin panel is disabled; /api/admin/* answers 503
#                          and /admin/login cannot sign anyone in. This is the
#                          default, and every deployment that predates the admin
#                          panel keeps booting unchanged.
#   - Set both          -> the panel is enabled.
#   - Set only one      -> the backend REFUSES TO START, naming the missing one.
#                          A half-configured admin is a silent 503 otherwise.
#
# ADMIN_PASSWORD_HASH is a bcrypt hash — NEVER a plaintext password. The backend
# validates the shape at boot and exits if it isn't one, deliberately: bcrypt
# compares a plaintext value to `false` forever, so a plaintext here would lock
# the admin out with no error anywhere. Generate one (from backend/):
#
#   node -e "console.log(require('bcrypt').hashSync(process.argv[1],12))" 'your-password'
#
# Quote the value: a bcrypt hash contains `$`, which docker compose interpolates
# in some contexts and most shells expand. Rotating the password = new hash +
# redeploy; the restart also ends every Admin Session, which IS how you revoke
# one (there is no admin revoke endpoint in Phase 0.1).
ADMIN_USERNAME=
ADMIN_PASSWORD_HASH=

# Sentry error tracking (optional). Leave unset to disable, e.g. local dev/test.
SENTRY_DSN=

# NOTE: each user's spreadsheet is auto-created on first login (no shared sheet id).
# NOTE: the OAuth client needs both the spreadsheets and drive.file scopes —
# drive.file is what lets us detect a spreadsheet the user moved to Trash (the
# Sheets API cannot: a trashed sheet reads and writes normally and never 404s).
